# MongoDB Atlas Connection String
# Get this from your MongoDB Atlas dashboard: https://cloud.mongodb.com/
# Example: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/arch-design?retryWrites=true&w=majority
MONGODB_URI=your_mongodb_uri

# Cloudinary Configuration
# Get these values from your Cloudinary dashboard: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
